          radial-gradient(ellipse at 18% 45%, rgba(255,255,255,0.95) 0%, transparent 18%),
          radial-gradient(ellipse at 72% 22%, rgba(240,171,252,0.85) 0%, transparent 22%),
          radial-gradient(ellipse at 48% 78%, rgba(192,132,252,0.9) 0%, transparent 28%),
          radial-gradient(ellipse at 85% 65%, rgba(255,255,255,0.6) 0%, transparent 14%),
          linear-gradient(125deg, #0d0020 0%, #3b0764 22%, #6d28d9 46%, #a855f7 66%, #c084fc 82%, #f0abfc 100%) !important;
        -webkit-background-clip:text !important;
        background-clip:text !important;
        -webkit-text-fill-color:transparent !important;
