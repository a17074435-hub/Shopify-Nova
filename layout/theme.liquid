<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
      /* ── NovaLight v5 · Crystal Islands ── */

      /* 0 — Tokens */
      :root {
        --nova-purple:      #A855F7;
        --nova-purple-deep: #7C3AED;
        --nova-ease:        cubic-bezier(0.16,1,0.3,1);
        --glass-purple:     rgba(109,40,217,0.08);
        --glass-dark:       rgba(5,0,20,0.85);
        --glass-border:     rgba(168,85,247,0.22);
        --font-heading--family:    'Space Grotesk',-apple-system,sans-serif;
        --font-subheading--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h1--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-h2--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-h3--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-h4--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-h5--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-h6--family:  'Space Grotesk',-apple-system,sans-serif;
        --font-size--h1:    clamp(3rem,8vw,6.5rem);
        --font-size--h2:    clamp(2rem,5vw,4rem);
        --font-size--h3:    clamp(1.5rem,3vw,2.5rem);
        --font-h1--size:    clamp(3rem,8vw,6.5rem);
        --font-h2--size:    clamp(2rem,5vw,4rem);
        --font-h3--size:    clamp(1.5rem,3vw,2.5rem);
        --letter-spacing--heading-tight:  -0.04em;
        --letter-spacing--heading-normal: -0.02em;
        --letter-spacing--display-tight:  -0.045em;
        --line-height--heading-tight:  1.05;
        --line-height--heading-normal: 1.1;
      }

      /* Keyframes */
      @keyframes nova-drift-a {
        0%,100% { transform:translate(0,0) scale(1); }
        40%     { transform:translate(-3vw,4vh) scale(1.08); }
        70%     { transform:translate(2vw,-2vh) scale(0.94); }
      }
      @keyframes nova-drift-b {
        0%,100% { transform:translate(0,0) scale(1); }
        35%     { transform:translate(4vw,-3vh) scale(1.06); }
        65%     { transform:translate(-2vw,3vh) scale(0.96); }
      }
      @keyframes nova-twinkle {
        0%,100% { opacity:0.05; transform:scale(0.3); }
        50%     { opacity:1;    transform:scale(1); }
      }
      @keyframes nova-orbit {
        0%   { transform:rotate(0deg)   translateX(42px); }
        100% { transform:rotate(360deg) translateX(42px); }
      }

      /* 1 — Base */
      html, body { background:#040010 !important; }
      body { -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }
      ::selection { background:rgba(168,85,247,0.28); color:#fff; }
      #header-group, #MainContent, footer { position:relative; z-index:1; }

      /* 2 — Section transparency (stars show through) */
      /* Radiant uses div.section-background for section color — that's the black layer */
      .section-background { background:transparent !important; background-color:transparent !important; }
      .shopify-section { background:transparent !important; }
      .shopify-section > section,
      .shopify-section > .section { background:transparent !important; }
      /* catch any remaining color-scheme wrappers */
      .shopify-section [class*="color-scheme-"] { background-color:transparent !important; }

      /* 2b — Section spacing — premium breathing room */
      .shopify-section:not(.shopify-section:first-child) > section,
      .shopify-section:not(.shopify-section:first-child) > .section {
        padding-top:max(72px,7vh) !important;
        padding-bottom:max(72px,7vh) !important;
      }
      /* body text: clear hierarchy */
      body, .rte, .text-block.paragraph > * {
        font-size:clamp(15px,1.1vw,17px);
        line-height:1.72;
      }
      p, .rte p { color:rgba(255,255,255,0.72) !important; }
      /* secondary/caption text */
      .product-card .price__vendor,
      .product-card .product-card__subtitle,
      figcaption, .caption { color:#A1A1AA !important; font-size:0.82rem !important; }

      /* 3 — Ambient blobs */
      #nova-atm {
        position:fixed; inset:0;
        pointer-events:none; z-index:0; overflow:hidden;
      }
      #nova-atm::before {
        content:''; position:absolute;
        top:-25vh; right:-15vw;
        width:70vw; height:70vw; border-radius:50%;
        background:radial-gradient(circle at center,
          rgba(124,58,237,0.18) 0%,
          rgba(109,40,217,0.08) 35%,
          transparent 65%);
        animation:nova-drift-a 18s ease-in-out infinite;
      }
      #nova-atm::after {
        content:''; position:absolute;
        bottom:-20vh; left:-20vw;
        width:62vw; height:62vw; border-radius:50%;
        background:radial-gradient(circle at center,
          rgba(139,92,246,0.14) 0%,
          rgba(124,58,237,0.06) 40%,
          transparent 65%);
        animation:nova-drift-b 24s ease-in-out infinite;
      }
      @media (prefers-reduced-motion:reduce) {
        #nova-atm::before, #nova-atm::after { animation:none; }
      }

      /* Stars */
      .nova-star {
        position:absolute;
        border-radius:50%;
        pointer-events:none;
        animation:nova-twinkle var(--dur,3s) ease-in-out infinite;
        animation-delay:var(--del,0s);
      }

      /* 4 — Typography */
      .text-block.h1 > *,
      .text-block.h1 :is(h1,h2,h3,h4,h5,h6),
      .text-block.h2 > *,
      .text-block.h2 :is(h1,h2,h3,h4,h5,h6),
      .text-block.h3 > *,
      .text-block.h3 :is(h1,h2,h3,h4,h5,h6),
      h1,h2,h3 { font-family:'Space Grotesk',-apple-system,sans-serif !important; }
      .text-block.h1 > * { font-size:clamp(3rem,8vw,6.5rem) !important; letter-spacing:-0.04em !important; line-height:1.05 !important; }
      .text-block.h2 > * { font-size:clamp(2rem,5vw,4rem) !important; letter-spacing:-0.03em !important; line-height:1.1 !important; }
      .text-block.h3 > * { font-size:clamp(1.5rem,3vw,2.5rem) !important; }

      /* 5 — Section headings — neon purple */
      :not(.hero) .text-block.h2 > *,
      :not(.hero) .text-block.h3 > * {
        color:var(--nova-purple) !important;
        text-shadow:0 0 22px rgba(168,85,247,0.35) !important;
      }

      /* 6 — Announcement bar — crystal glass */
      .announcement-bar {
        background:rgba(90,28,200,0.22) !important;
        backdrop-filter:blur(20px) saturate(1.8) !important;
        -webkit-backdrop-filter:blur(20px) saturate(1.8) !important;
        border-bottom:1px solid rgba(168,85,247,0.3) !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.09),0 2px 20px rgba(109,40,217,0.3) !important;
      }
      .announcement-bar__text,.announcement-bar {
        font-size:0.7rem !important; letter-spacing:0.1em !important; text-transform:uppercase !important;
        color:#fff !important; text-shadow:0 0 12px rgba(255,255,255,0.3) !important;
      }

      /* 7 — Header — always transparent, only pills float */
      header-component,
      header-component .header,
      .header {
        background:transparent !important;
        background-color:transparent !important;
      }
      /* underlay divs carry the actual color-scheme gradient — nuke them */
      .header__underlay-closed,
      .header__underlay-open {
        background:transparent !important;
        background-color:transparent !important;
      }
      header-component[data-sticky-state="active"] .header,
      header-component[sticky="always"] .header {
        backdrop-filter:none !important;
        -webkit-backdrop-filter:none !important;
        background:transparent !important;
        border-bottom:none !important;
        box-shadow:none !important;
      }
      .header__nav-link:hover,.header__nav-link:focus-visible { color:var(--nova-purple) !important; }

      /* 7b — Logo orbit sparkle (desktop) */
      @media screen and (min-width:750px) {
        .header-logo {
          position:relative !important;
          overflow:visible !important;
          z-index:2 !important;
        }
        .header-logo::after {
          content:'' !important;
          position:absolute !important;
          top:50% !important; left:50% !important;
          width:7px !important; height:7px !important;
          margin:-3.5px 0 0 -3.5px !important;
          border-radius:50% !important;
          background:var(--nova-purple) !important;
          box-shadow:0 0 6px 3px var(--nova-purple),0 0 18px rgba(168,85,247,0.8) !important;
          animation:nova-orbit 5s linear infinite !important;
          z-index:10 !important;
          pointer-events:none !important;
        }
      }
      @media (prefers-reduced-motion:reduce) { .header-logo::after { animation:none !important; } }

      /* 7c — Nav pill (desktop) — opaque enough to always look like glass on scroll */
      @media screen and (min-width:750px) {
        header-menu {
          background:rgba(16,5,45,0.78) !important;
          backdrop-filter:blur(28px) saturate(1.8) !important;
          -webkit-backdrop-filter:blur(28px) saturate(1.8) !important;
          border:1px solid rgba(168,85,247,0.30) !important;
          border-radius:100px !important;
          padding:2px 8px !important;
          box-shadow:inset 0 1px 0 rgba(255,255,255,0.09),0 4px 24px rgba(0,0,0,0.45) !important;
        }
        .header-menu .menu-list__link {
          border-radius:100px !important;
          padding:6px 16px !important;
          transition:background .3s var(--nova-ease),color .3s var(--nova-ease) !important;
        }
        .header-menu .menu-list__link:hover,
        .header-menu .menu-list__link:focus-visible {
          background:rgba(168,85,247,0.14) !important;
          color:var(--nova-purple) !important;
        }
      }

      /* 7d — Right column pill: wraps search + actions in one glass pill */
      @media screen and (min-width:750px) {
        .header__column--right {
          background:rgba(16,5,45,0.78) !important;
          backdrop-filter:blur(28px) saturate(1.8) !important;
          -webkit-backdrop-filter:blur(28px) saturate(1.8) !important;
          border:1px solid rgba(168,85,247,0.30) !important;
          border-radius:100px !important;
          padding:2px 4px !important;
          box-shadow:inset 0 1px 0 rgba(255,255,255,0.09),0 4px 24px rgba(0,0,0,0.45) !important;
          display:flex !important;
          align-items:center !important;
          gap:0 !important;
          width:fit-content !important;
          margin-left:auto !important;
          align-self:center !important;
        }
      }
      /* header-actions itself transparent — parent column is the pill */
      header-actions {
        background:transparent !important;
        border:none !important;
        box-shadow:none !important;
        backdrop-filter:none !important;
        -webkit-backdrop-filter:none !important;
        display:flex !important;
        align-items:center !important;
        gap:1px !important;
        padding:0 !important;
      }
      /* Search button inside the pill */
      .search-action {
        border-radius:100px !important;
        padding:5px 9px !important;
        background:transparent !important;
        border:none !important;
        color:inherit !important;
        transition:background .3s var(--nova-ease) !important;
      }
      .search-action:hover { background:rgba(168,85,247,0.16) !important; }
      .header-actions__action {
        border-radius:100px !important;
        padding:5px 9px !important;
        transition:background .3s var(--nova-ease),color .3s var(--nova-ease) !important;
        background:transparent !important;
        border:none !important;
        min-width:unset !important;
        min-height:unset !important;
        aspect-ratio:auto !important;
      }
      .header-actions__action:hover { background:rgba(168,85,247,0.16) !important; }
      /* Cart icon area — fix square */
      cart-drawer-component {
        background:transparent !important;
        border:none !important;
        display:flex !important;
        align-items:center !important;
      }
      .action__cart, .header-actions__cart-icon, cart-icon {
        background:transparent !important;
        border:none !important;
      }

      /* 7e — Cart bubble — circular purple */
      .cart-bubble__background {
        background:var(--nova-purple) !important;
        border-radius:50% !important;
      }
      .cart-bubble__text-count,
      .cart-bubble__text { color:#fff !important; }

      /* 7f — Hamburger menu pill (mobile) */
      @media screen and (max-width:749px) {
        .header__icon--menu {
          background:rgba(255,255,255,0.04) !important;
          backdrop-filter:blur(20px) !important;
          -webkit-backdrop-filter:blur(20px) !important;
          border:1px solid rgba(168,85,247,0.24) !important;
          border-radius:100px !important;
          padding:7px 12px !important;
        }
      }

      /* 8 — Hero */
      .hero { position:relative !important; overflow:hidden; }
      .hero::after {
        content:'' !important; position:absolute !important; inset:0 !important;
        pointer-events:none !important; z-index:3 !important;
        background:radial-gradient(ellipse 90% 55% at 50% 110%,rgba(124,58,237,0.52) 0%,transparent 60%) !important;
      }
      .hero .text-block.h1 > *,
      .hero .text-block.h1 :is(h1,h2,h3,h4,h5,h6) {
        font-weight:700 !important; text-shadow:0 2px 40px rgba(0,0,0,0.65) !important;
        position:relative; z-index:4;
        color:#fff !important;
      }
      .hero .text-block.paragraph > *, .hero .text-block.rte p {
        opacity:0.78 !important; line-height:1.65 !important; position:relative; z-index:4;
      }
      .hero hr { border-color:rgba(168,85,247,0.65) !important; width:36px !important; }

      /* 9 — Product cards — glass windows with gap */
      /* Grid gap — override Radiant CSS vars + direct gap */
      resource-list {
        --resource-list-column-gap-desktop: 16px !important;
        --resource-list-row-gap-desktop: 16px !important;
        --resource-list-column-gap: 16px !important;
        --resource-list-row-gap: 16px !important;
        gap:16px !important;
      }
      .resource-list--grid,
      .product-list .resource-list,
      .product-list .resource-grid {
        gap:16px !important;
        column-gap:16px !important;
        row-gap:16px !important;
      }
      .product-card .product-card__image,
      .product-card .media,
      .product-card .card-media { overflow:hidden !important; }
      .product-card .product-card__image img,
      .product-card .media img,
      .product-card .card-media img { transition:transform 0.6s var(--nova-ease) !important; }
      .product-card {
        background:rgba(109,40,217,0.09) !important;
        backdrop-filter:blur(20px) saturate(1.4) !important;
        -webkit-backdrop-filter:blur(20px) saturate(1.4) !important;
        border:1px solid rgba(168,85,247,0.25) !important;
        border-radius:18px !important;
        overflow:hidden !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.07),inset 0 0 0 1px rgba(168,85,247,0.08),0 16px 40px rgba(0,0,0,0.45) !important;
        transition:transform .4s var(--nova-ease),box-shadow .4s var(--nova-ease),border-color .4s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) and (prefers-reduced-motion:no-preference) {
        .product-card:hover {
          transform:translateY(-4px) scale(1.015) !important;
          border-color:rgba(168,85,247,0.42) !important;
          box-shadow:inset 0 1px 0 rgba(255,255,255,0.08),0 24px 48px rgba(0,0,0,0.5),0 0 36px rgba(124,58,237,0.2) !important;
        }
        /* subtle image zoom inside card on hover */
        .product-card:hover .product-card__image img,
        .product-card:hover .media img,
        .product-card:hover .card-media img {
          transform:scale(1.04) !important;
          transition:transform 0.6s var(--nova-ease) !important;
        }
      }

      /* 9b — Product titles — neon purple */
      .product-card product-title,
      .product-card product-title a,
      .product-card-gallery__title-placeholder,
      .product-card-gallery__title-placeholder a,
      .product-card .text-block > * {
        color:var(--nova-purple) !important;
        text-shadow:0 0 16px rgba(168,85,247,0.3) !important;
      }

      /* 9c — Prices */
      .price .price-item--sale,
      .price .price-item--regular,
      .price__current,
      .price-item--regular {
        color:#fff !important;
        font-weight:700 !important;
        font-size:1.05em !important;
        text-shadow:0 0 12px rgba(255,255,255,0.35) !important;
        letter-spacing:-0.02em !important;
      }
      /* Compare-at (original price when on sale) — red neon strikethrough */
      .price .price-item--compare-at,
      .price--compare-at,
      s.price-item {
        color:rgba(255,85,85,1) !important;
        text-decoration:line-through !important;
        text-shadow:0 0 10px rgba(255,80,80,0.5) !important;
        opacity:1 !important;
        font-weight:500 !important;
      }

      /* 9d — Quick-add glass button — always visible, expands on hover */
      .quick-add__button {
        opacity:1 !important;           /* always visible, override Radiant's opacity:0 */
        visibility:visible !important;
      }
      .product-card .quick-add__button,
      .product-card [data-quick-add-btn],
      .product-card .card__add-to-cart {
        background:rgba(109,40,217,0.28) !important;
        backdrop-filter:blur(14px) !important;
        -webkit-backdrop-filter:blur(14px) !important;
        border:1px solid rgba(168,85,247,0.52) !important;
        border-radius:100px !important;
        color:#fff !important;
        font-weight:600 !important;
        letter-spacing:0.03em !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.1),0 4px 16px rgba(0,0,0,0.3) !important;
        transition:transform .28s var(--nova-ease),box-shadow .28s var(--nova-ease),background .28s var(--nova-ease),scale .28s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .product-card .quick-add__button:hover,
        .product-card [data-quick-add-btn]:hover,
        .product-card .card__add-to-cart:hover {
          background:var(--nova-purple) !important;
          border-color:var(--nova-purple) !important;
          box-shadow:0 0 28px rgba(124,58,237,0.65),0 0 60px rgba(124,58,237,0.28) !important;
          scale:1.07 !important;          /* expand on hover */
          transform:translateY(-2px) !important;
        }
      }

      /* 10 — Primary button — white + black (premium/Apple style) */
      /* Exclude quick-add, close, and cart buttons from white styling */
      .button:not(.button-secondary,.button-unstyled,.quick-add__button,.card__add-to-cart,.close-button,.cart__checkout-button) {
        background:#fff !important;
        color:#0a0a0a !important;
        border-color:#fff !important;
        border-radius:14px !important;
        font-weight:600 !important;
        letter-spacing:0.01em !important;
        transition:background .35s var(--nova-ease),color .35s var(--nova-ease),box-shadow .35s var(--nova-ease),transform .22s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .button:not(.button-secondary,.button-unstyled,.quick-add__button,.card__add-to-cart,.close-button,.cart__checkout-button):hover {
          background:#f0e6ff !important;
          color:#0a0a0a !important;
          border-color:#f0e6ff !important;
          transform:translateY(-2px) !important;
          box-shadow:0 0 28px rgba(123,46,255,0.45),0 8px 24px rgba(0,0,0,0.3) !important;
        }
        .button:not(.button-secondary,.button-unstyled,.quick-add__button,.card__add-to-cart,.close-button):active { transform:translateY(0) !important; }
      }

      /* 11 — Secondary/ghost button — glass */
      .button-secondary {
        background:rgba(109,40,217,0.08) !important;
        backdrop-filter:blur(12px) !important;
        -webkit-backdrop-filter:blur(12px) !important;
        border:1px solid rgba(168,85,247,0.42) !important;
        color:#fff !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.07) !important;
        transition:all .4s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .button-secondary:hover {
          border-color:var(--nova-purple) !important;
          background:rgba(168,85,247,0.15) !important;
          box-shadow:inset 0 1px 0 rgba(255,255,255,0.1),0 0 28px rgba(124,58,237,0.4) !important;
          transform:translateY(-2px) !important;
        }
        .button-secondary:active { transform:translateY(0) !important; }
      }

      /* 12 — Purple accents */
      .badge--sale { background-color:var(--nova-purple) !important; border-color:var(--nova-purple) !important; color:#fff !important; }
      .variant-option__button-label:has(:checked) { box-shadow:0 0 0 2px var(--nova-purple) !important; }
      .variant-option__button-label--has-swatch:has(:checked) { outline:2px solid var(--nova-purple) !important; outline-offset:2px !important; }
      .thumbnail[aria-current="true"],.thumbnail[aria-selected="true"] { outline:2px solid var(--nova-purple) !important; outline-offset:2px !important; }

      /* 13 — Inputs */
      input:focus-visible,textarea:focus-visible,select:focus-visible {
        outline:none !important; border-color:var(--nova-purple) !important;
        box-shadow:0 0 0 3px rgba(168,85,247,0.2) !important;
      }

      /* 14 — Cart drawer — frosted glass window */
      .cart-drawer__overlay,.drawer__overlay {
        backdrop-filter:blur(10px) brightness(0.35) !important;
        -webkit-backdrop-filter:blur(10px) brightness(0.35) !important;
        background:rgba(0,0,0,0.55) !important;
      }
      /* .cart-drawer__dialog is the actual color-scheme element — override to glass */
      /* NOTE: do NOT add .cart-drawer here — that class is on cart-drawer-component in the header */
      .cart-drawer__dialog {
        background:rgba(75,18,155,0.42) !important;
        backdrop-filter:blur(48px) saturate(1.6) !important;
        -webkit-backdrop-filter:blur(48px) saturate(1.6) !important;
        border-left:1px solid rgba(168,85,247,0.40) !important;
        border-radius:20px 0 0 20px !important;
        box-shadow:-24px 0 60px rgba(0,0,0,0.35),inset 1px 0 0 rgba(168,85,247,0.35),inset 0 1px 0 rgba(255,255,255,0.06),inset 0 0 80px rgba(109,40,217,0.12) !important;
      }
      /* cart-drawer-component wrapper in the header must be invisible */
      cart-drawer-component.cart-drawer {
        background:transparent !important;
        border:none !important;
        box-shadow:none !important;
        backdrop-filter:none !important;
      }
      /* Force all inner wrappers transparent so the glass dialog shows through */
      .cart-drawer__inner,
      .cart-drawer__content,
      .cart-drawer__items,
      scroll-hint { background:transparent !important; }
      /* Hide scrollbar inside cart while keeping scroll functional */
      .cart-drawer__dialog scroll-hint,
      .cart-drawer__content,
      .cart-drawer__items {
        scrollbar-width:none !important;
        -ms-overflow-style:none !important;
      }
      .cart-drawer__dialog scroll-hint::-webkit-scrollbar,
      .cart-drawer__content::-webkit-scrollbar,
      .cart-drawer__items::-webkit-scrollbar { display:none !important; }
      /* Cart header */
      .cart-drawer__header {
        background:rgba(168,85,247,0.07) !important;
        border-bottom:1px solid rgba(168,85,247,0.18) !important;
      }
      .cart-drawer__heading {
        color:var(--nova-purple) !important;
        text-shadow:0 0 18px rgba(168,85,247,0.5) !important;
        font-weight:700 !important;
        display:flex !important;
        align-items:center !important;
        gap:0.4em !important;
      }
      .nova-cart-heading-icon {
        display:inline-flex !important;
        align-items:center !important;
        width:1.15em !important;
        height:1.15em !important;
        flex-shrink:0 !important;
        color:var(--nova-purple) !important;
        filter:drop-shadow(0 0 8px rgba(168,85,247,0.75)) !important;
      }
      .nova-cart-heading-icon svg {
        width:100% !important;
        height:100% !important;
      }
      /* Cart item rows */
      .cart-drawer__items .cart-items__table-row {
        border-bottom:1px solid rgba(168,85,247,0.1) !important;
      }
      /* Cart product titles */
      .cart-drawer__items .cart-items__name,
      .cart-drawer__items a[href*="/products"] {
        color:var(--nova-purple) !important;
      }
      /* Cart summary footer */
      .cart-drawer__summary {
        background:rgba(168,85,247,0.06) !important;
        border-top:1px solid rgba(168,85,247,0.22) !important;
      }
      /* Checkout button — purple pill + neon glow */
      .cart-drawer__summary .button,
      .cart-drawer__summary [href*="checkout"],
      .cart__checkout-button {
        background:var(--nova-purple) !important;
        border-color:var(--nova-purple) !important;
        color:#fff !important;
        border-radius:100px !important;
        font-weight:700 !important;
        letter-spacing:0.04em !important;
        box-shadow:0 0 24px rgba(124,58,237,0.55),0 0 48px rgba(124,58,237,0.2) !important;
        transition:transform .3s var(--nova-ease),box-shadow .3s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .cart-drawer__summary .button:hover,
        .cart-drawer__summary [href*="checkout"]:hover,
        .cart__checkout-button:hover {
          transform:translateY(-3px) !important;
          box-shadow:0 0 40px rgba(124,58,237,0.75),0 0 80px rgba(124,58,237,0.35) !important;
        }
      }
      /* Quantity selector glass */
      .cart-drawer .quantity-selector,
      .cart-drawer .component-quantity {
        background:rgba(109,40,217,0.12) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:100px !important;
      }

      /* Close buttons — spin + purple on hover (all dialogs/drawers) */
      .close-button {
        border-radius:50% !important;
        transition:transform .35s var(--nova-ease),color .3s,background .3s !important;
        padding:6px !important;
      }
      .close-button:hover {
        transform:rotate(90deg) scale(1.22) !important;
        color:var(--nova-purple) !important;
        background:rgba(168,85,247,0.12) !important;
      }
      .close-button:active {
        transform:rotate(180deg) scale(0.9) !important;
      }

      /* 15 — Popovers */
      .popover-container {
        background:rgba(8,0,28,0.92) !important;
        backdrop-filter:blur(24px) saturate(1.4) !important;
        -webkit-backdrop-filter:blur(24px) saturate(1.4) !important;
        border:1px solid rgba(168,85,247,0.24) !important;
        box-shadow:0 20px 60px rgba(0,0,0,0.65) !important;
      }
      predictive-search-component { border:1px solid rgba(168,85,247,0.2) !important; }

      /* 16 — Marquee — neon white */
      .marquee {
        border-top:1px solid rgba(168,85,247,0.25) !important;
        border-bottom:1px solid rgba(168,85,247,0.25) !important;
        background:rgba(109,40,217,0.06) !important;
      }
      .marquee .text-block > *,
      .marquee p,
      .marquee span {
        color:#fff !important;
        text-shadow:0 0 18px rgba(255,255,255,0.7),0 0 40px rgba(255,255,255,0.3) !important;
        opacity:1 !important;
        letter-spacing:0.04em !important;
      }

      /* 17a — Email signup heading — galaxy text */
      .email-signup__heading,
      .email-signup__heading * {
        font-weight:800 !important;
        font-size:clamp(1.8rem,4vw,3.2rem) !important;
        background:
          radial-gradient(ellipse at 18% 45%, rgba(255,255,255,0.95) 0%, transparent 18%),
          radial-gradient(ellipse at 72% 22%, rgba(240,171,252,0.85) 0%, transparent 22%),
          radial-gradient(ellipse at 48% 78%, rgba(192,132,252,0.9) 0%, transparent 28%),
          radial-gradient(ellipse at 85% 65%, rgba(255,255,255,0.6) 0%, transparent 14%),
          linear-gradient(125deg, #0d0020 0%, #3b0764 22%, #6d28d9 46%, #a855f7 66%, #c084fc 82%, #f0abfc 100%) !important;
        -webkit-background-clip:text !important;
        background-clip:text !important;
        -webkit-text-fill-color:transparent !important;
        filter:drop-shadow(0 0 14px rgba(168,85,247,0.75)) drop-shadow(0 0 32px rgba(124,58,237,0.45)) !important;
        line-height:1.1 !important;
        letter-spacing:-0.02em !important;
      }

      /* 17 — Email signup — crystal glass */
      .email-signup__input,
      .email-signup__input-group--integrated {
        background:rgba(109,40,217,0.1) !important;
        backdrop-filter:blur(16px) !important;
        -webkit-backdrop-filter:blur(16px) !important;
        border:1px solid rgba(168,85,247,0.4) !important;
        border-radius:100px !important;
        color:#fff !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.06),0 0 0 0 transparent !important;
        transition:border-color .3s,box-shadow .3s !important;
      }
      .email-signup__input:focus {
        border-color:var(--nova-purple) !important;
        box-shadow:0 0 0 3px rgba(168,85,247,0.2),inset 0 1px 0 rgba(255,255,255,0.08) !important;
      }
      .email-signup__button {
        background:rgba(109,40,217,0.28) !important;
        backdrop-filter:blur(14px) !important;
        -webkit-backdrop-filter:blur(14px) !important;
        border:1px solid rgba(168,85,247,0.5) !important;
        border-radius:100px !important;
        color:#fff !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.1) !important;
        transition:all .3s var(--nova-ease) !important;
      }
      .email-signup__button:hover {
        background:var(--nova-purple) !important;
        box-shadow:0 0 24px rgba(124,58,237,0.6) !important;
        border-color:var(--nova-purple) !important;
      }

      /* 18 — Filter/sort bar — full glass redesign */

      /* Whole bar */
      .facets-toggle {
        background:rgba(8,0,26,0.52) !important;
        backdrop-filter:blur(24px) saturate(1.6) !important;
        -webkit-backdrop-filter:blur(24px) saturate(1.6) !important;
        border:1px solid rgba(168,85,247,0.2) !important;
        border-radius:16px !important;
        box-shadow:inset 0 1px 0 rgba(255,255,255,0.06),0 8px 32px rgba(0,0,0,0.4) !important;
      }

      /* Filter dropdown pill buttons (Availability, Price…) */
      .facets__summary {
        display:flex !important;
        align-items:center !important;
        gap:6px !important;
        background:rgba(109,40,217,0.1) !important;
        backdrop-filter:blur(14px) !important;
        -webkit-backdrop-filter:blur(14px) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:100px !important;
        padding:8px 16px !important;
        cursor:pointer !important;
        list-style:none !important;
        transition:all .3s var(--nova-ease) !important;
      }
      .facets__summary:hover,
      details[open] > .facets__summary {
        background:rgba(168,85,247,0.18) !important;
        border-color:var(--nova-purple) !important;
        box-shadow:0 0 16px rgba(168,85,247,0.3) !important;
      }
      .facets__label {
        color:#fff !important;
        font-weight:500 !important;
        font-size:0.84rem !important;
        letter-spacing:0.05em !important;
        white-space:nowrap !important;
      }
      /* Active filter count bubble */
      .facets__bubble,
      span.bubble.facets__bubble {
        background:var(--nova-purple) !important;
        border-radius:100px !important;
        color:#fff !important;
        font-size:0.7rem !important;
        padding:2px 7px !important;
      }

      /* Filter dropdown panel — glass crystal matching rest of UI */
      .facets__inputs.facets__panel-content,
      .facets__panel-content {
        background:rgba(20,6,55,0.82) !important;
        backdrop-filter:blur(32px) saturate(1.5) !important;
        -webkit-backdrop-filter:blur(32px) saturate(1.5) !important;
        border:1px solid rgba(168,85,247,0.30) !important;
        border-radius:16px !important;
        box-shadow:0 16px 48px rgba(0,0,0,0.5),inset 0 1px 0 rgba(255,255,255,0.06) !important;
        padding:16px !important;
        margin-top:8px !important;
        min-width:200px !important;
      }
      .facets__inputs label,
      .facets__inputs .facets__option-label {
        color:rgba(255,255,255,0.82) !important;
        transition:color .2s !important;
        cursor:pointer !important;
      }
      .facets__inputs label:hover,
      .facets__inputs .facets__option-label:hover { color:var(--nova-purple) !important; }

      /* Price range inputs */
      .price-facet__inputs-wrapper {
        display:flex !important;
        align-items:center !important;
        gap:10px !important;
        justify-content:center !important;
      }
      .price-facet__field {
        position:relative !important;
        display:flex !important;
        align-items:center !important;
        background:rgba(109,40,217,0.12) !important;
        border:1px solid rgba(168,85,247,0.35) !important;
        border-radius:10px !important;
        padding:0 10px !important;
        gap:4px !important;
        transition:border-color .2s,box-shadow .2s !important;
      }
      .price-facet__field:focus-within {
        border-color:var(--nova-purple) !important;
        box-shadow:0 0 0 3px rgba(168,85,247,0.2) !important;
      }
      .price-facet__label {
        color:rgba(168,85,247,0.85) !important;
        font-size:0.82rem !important;
        font-weight:600 !important;
        pointer-events:none !important;
        position:static !important;
        transform:none !important;
        flex-shrink:0 !important;
      }
      .price-facet__input {
        background:transparent !important;
        border:none !important;
        outline:none !important;
        color:#fff !important;
        font-size:0.88rem !important;
        font-weight:500 !important;
        width:70px !important;
        padding:8px 0 !important;
        text-align:right !important;
        box-shadow:none !important;
      }
      .price-facet__input::placeholder { color:rgba(255,255,255,0.3) !important; }
      .price-facet__separator {
        color:rgba(168,85,247,0.6) !important;
        font-size:0.85rem !important;
        flex-shrink:0 !important;
      }
      .price-facet__highest-price {
        color:rgba(255,255,255,0.42) !important;
        font-size:0.75rem !important;
        text-align:center !important;
        margin-top:10px !important;
      }

      /* Filter toggle button (drawer style) */
      .facets-toggle__button {
        background:rgba(109,40,217,0.1) !important;
        backdrop-filter:blur(14px) !important;
        -webkit-backdrop-filter:blur(14px) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:100px !important;
        color:#fff !important;
        font-weight:500 !important;
        padding:8px 18px !important;
        display:flex !important; align-items:center !important; gap:8px !important;
        transition:all .3s var(--nova-ease) !important;
      }
      .facets-toggle__button:hover {
        background:rgba(168,85,247,0.18) !important;
        border-color:var(--nova-purple) !important;
        box-shadow:0 0 18px rgba(168,85,247,0.28) !important;
        color:var(--nova-purple) !important;
      }

      /* Sort select */
      .sorting-filter__select-wrapper {
        background:rgba(109,40,217,0.1) !important;
        backdrop-filter:blur(14px) !important;
        -webkit-backdrop-filter:blur(14px) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:100px !important;
        padding:0 6px !important;
        display:flex !important; align-items:center !important;
        transition:border-color .3s,box-shadow .3s !important;
      }
      .sorting-filter__select-wrapper:hover {
        border-color:var(--nova-purple) !important;
        box-shadow:0 0 14px rgba(168,85,247,0.22) !important;
      }
      .sorting-filter__select {
        color:#fff !important;
        background:transparent !important;
        font-weight:500 !important;
        font-size:0.84rem !important;
        letter-spacing:0.04em !important;
        padding:8px 10px !important;
        cursor:pointer !important;
      }

      /* Sort dropdown panel */
      .sorting-filter__options {
        background:rgba(6,0,22,0.94) !important;
        backdrop-filter:blur(28px) !important;
        -webkit-backdrop-filter:blur(28px) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:14px !important;
        box-shadow:0 16px 48px rgba(0,0,0,0.65) !important;
        overflow:hidden !important;
        padding:6px !important;
      }
      .sorting-filter__option { border-radius:8px !important; transition:background .2s !important; }
      .sorting-filter__option:hover { background:rgba(168,85,247,0.14) !important; }
      .sorting-filter__label { color:rgba(255,255,255,0.85) !important; font-size:0.84rem !important; }
      .sorting-filter__option:has(:checked) .sorting-filter__label { color:var(--nova-purple) !important; }
      .sorting-filter__checkmark { color:var(--nova-purple) !important; }

      /* Item count */
      .products-count-wrapper {
        color:rgba(255,255,255,0.45) !important;
        font-size:0.8rem !important;
        letter-spacing:0.05em !important;
      }

      /* Grid density controls */
      .column-options-wrapper {
        background:rgba(109,40,217,0.1) !important;
        border:1px solid rgba(168,85,247,0.24) !important;
        border-radius:100px !important;
        padding:3px 4px !important;
        display:flex !important;
        gap:2px !important;
      }
      .column-picker {
        border-radius:100px !important;
        padding:5px 7px !important;
        display:flex !important; align-items:center !important; justify-content:center !important;
        transition:background .25s,color .25s !important;
        color:rgba(255,255,255,0.4) !important;
        cursor:pointer !important;
      }
      .column-options__option:has(:checked) .column-picker {
        background:var(--nova-purple) !important;
        color:#fff !important;
        box-shadow:0 0 10px rgba(168,85,247,0.4) !important;
      }

      /* 19 — Social icons — free-floating crystal glass (no bubble) */
      /* Social icons — no bubble, platform colors, crystal glow */
      .social-icons__icon-wrapper {
        background:transparent !important;
        backdrop-filter:none !important;
        border:none !important;
        border-radius:0 !important;
        box-shadow:none !important;
        padding:8px !important;
        transition:transform .3s var(--nova-ease) !important;
      }
      .social-icons__icon-wrapper:hover {
        background:transparent !important;
        transform:translateY(-4px) scale(1.15) !important;
      }
      .social-icons__icon-wrapper { --icon-size-lg:52px !important; }
      .social-icons__icon {
        width:52px !important;
        height:52px !important;
        transition:filter .3s var(--nova-ease),color .3s !important;
      }
      /* Instagram — pink/rose */
      .social-icons__icon-wrapper:has([href*="instagram"]) .social-icons__icon {
        color:#E1306C !important;
        filter:drop-shadow(0 0 8px rgba(225,48,108,0.7)) drop-shadow(0 0 20px rgba(225,48,108,0.3)) !important;
      }
      .social-icons__icon-wrapper:has([href*="instagram"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(225,48,108,1)) drop-shadow(0 0 32px rgba(225,48,108,0.55)) !important;
      }
      /* YouTube — red */
      .social-icons__icon-wrapper:has([href*="youtube"]) .social-icons__icon {
        color:#FF0000 !important;
        filter:drop-shadow(0 0 8px rgba(255,0,0,0.65)) drop-shadow(0 0 20px rgba(255,0,0,0.28)) !important;
      }
      .social-icons__icon-wrapper:has([href*="youtube"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(255,0,0,1)) drop-shadow(0 0 32px rgba(255,0,0,0.5)) !important;
      }
      /* TikTok — teal/cyan */
      .social-icons__icon-wrapper:has([href*="tiktok"]) .social-icons__icon {
        color:#69C9D0 !important;
        filter:drop-shadow(0 0 8px rgba(105,201,208,0.7)) drop-shadow(0 0 20px rgba(105,201,208,0.3)) !important;
      }
      .social-icons__icon-wrapper:has([href*="tiktok"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(105,201,208,1)) drop-shadow(0 0 32px rgba(105,201,208,0.5)) !important;
      }
      /* X / Twitter — white */
      .social-icons__icon-wrapper:has([href*="twitter"]) .social-icons__icon,
      .social-icons__icon-wrapper:has([href*="x.com"]) .social-icons__icon {
        color:rgba(255,255,255,0.9) !important;
        filter:drop-shadow(0 0 8px rgba(255,255,255,0.45)) !important;
      }
      .social-icons__icon-wrapper:has([href*="twitter"]):hover .social-icons__icon,
      .social-icons__icon-wrapper:has([href*="x.com"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(255,255,255,0.9)) drop-shadow(0 0 28px rgba(255,255,255,0.4)) !important;
      }
      /* Threads — light purple/white */
      .social-icons__icon-wrapper:has([href*="threads"]) .social-icons__icon {
        color:rgba(220,200,255,0.92) !important;
        filter:drop-shadow(0 0 8px rgba(168,85,247,0.6)) !important;
      }
      .social-icons__icon-wrapper:has([href*="threads"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(168,85,247,1)) drop-shadow(0 0 28px rgba(168,85,247,0.5)) !important;
      }
      /* WhatsApp — green */
      .social-icons__icon-wrapper:has([href*="wa.me"]) .social-icons__icon,
      .social-icons__icon-wrapper:has([href*="whatsapp"]) .social-icons__icon {
        color:#25D366 !important;
        filter:drop-shadow(0 0 8px rgba(37,211,102,0.65)) !important;
      }
      .social-icons__icon-wrapper:has([href*="wa.me"]):hover .social-icons__icon,
      .social-icons__icon-wrapper:has([href*="whatsapp"]):hover .social-icons__icon {
        filter:drop-shadow(0 0 14px rgba(37,211,102,1)) drop-shadow(0 0 28px rgba(37,211,102,0.5)) !important;
      }
      /* Fallback for any other icon */
      .social-icons__icon-wrapper:not(:has([href*="instagram"],[href*="youtube"],[href*="tiktok"],[href*="twitter"],[href*="x.com"],[href*="threads"],[href*="wa.me"],[href*="whatsapp"])) .social-icons__icon {
        color:rgba(255,255,255,0.85) !important;
        filter:drop-shadow(0 0 8px rgba(168,85,247,0.55)) !important;
      }

      /* 20 — Dividers & footer */
      .divider hr,hr { border-color:rgba(168,85,247,0.15) !important; }
      footer > .shopify-section:first-child { border-top:1px solid rgba(168,85,247,0.2) !important; }

      /* 21 — Scrollbar */
      /* Hide scrollbar everywhere — scroll still works */
      html { scrollbar-width:none !important; -ms-overflow-style:none !important; }
      ::-webkit-scrollbar { display:none !important; width:0 !important; }

      /* 22 — Logo image */
      .nova-logo__img { height:64px !important; width:auto !important; max-width:280px !important; display:block !important; }
      @media (max-width:749px) { .nova-logo__img { height:42px !important; } }

      /* 23 — Product description toggle */
      .nova-desc-wrap { margin-top:12px; }
      .nova-desc-btn {
        display:flex; align-items:center; justify-content:space-between;
        width:100%;
        background:rgba(109,40,217,0.1);
        backdrop-filter:blur(12px);
        -webkit-backdrop-filter:blur(12px);
        border:1px solid rgba(168,85,247,0.28);
        border-radius:12px;
        padding:11px 18px;
        color:#fff;
        font-size:0.85rem;
        letter-spacing:0.06em;
        text-transform:uppercase;
        cursor:pointer;
        transition:border-color .3s var(--nova-ease),background .3s var(--nova-ease);
      }
      .nova-desc-btn:hover { border-color:var(--nova-purple); background:rgba(109,40,217,0.18); }
      .nova-desc-btn .nova-chev { display:inline-block; transition:transform .35s var(--nova-ease); font-style:normal; }
      .nova-desc-btn[aria-expanded="true"] .nova-chev { transform:rotate(180deg); }
      .nova-desc-body { display:grid; grid-template-rows:0fr; transition:grid-template-rows .4s var(--nova-ease); overflow:hidden; }
      .nova-desc-body.nova-open { grid-template-rows:1fr; }
      .nova-desc-body > div { min-height:0; padding-top:10px; }

      /* 24 — Hide sticky add-to-cart bar */
      sticky-add-to-cart { display:none !important; }

      /* 25 — Scroll reveal */
      @media (prefers-reduced-motion:no-preference) {
        .nova-reveal { opacity:0; transform:translateY(28px); transition:opacity .65s var(--nova-ease),transform .65s var(--nova-ease); }
        .nova-reveal.nova-visible { opacity:1 !important; transform:translateY(0) !important; }
      }

      /* 26 — Mobile touch targets */
      @media screen and (max-width:749px) {
        .button,.button-secondary { min-height:48px !important; }
      }
    </style>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    <div id="nova-atm" aria-hidden="true"></div>
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
      /* NovaLight v5 — star generator */
      (function () {
        if (window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
        var atm = document.getElementById('nova-atm');
        if (!atm) return;
        var palettes = [
          'rgba(168,85,247,OP)',
          'rgba(255,255,255,OP)',
          'rgba(192,132,252,OP)',
          'rgba(139,92,246,OP)',
          'rgba(255,255,255,OP)'
        ];
        for (var i = 0; i < 65; i++) {
          var el = document.createElement('div');
          el.className = 'nova-star';
          var sz = (Math.random() * 2.2 + 0.8).toFixed(1);
          var op = (Math.random() * 0.65 + 0.35).toFixed(2);
          var col = palettes[Math.floor(Math.random() * palettes.length)].replace('OP', op);
          var dur = (Math.random() * 4 + 2.5).toFixed(1);
          var del = (-(Math.random() * 8)).toFixed(1);
          el.style.cssText =
            'width:' + sz + 'px;height:' + sz + 'px;' +
            'top:' + (Math.random() * 100).toFixed(1) + '%;' +
            'left:' + (Math.random() * 100).toFixed(1) + '%;' +
            'background:' + col + ';' +
            'box-shadow:0 0 ' + (parseFloat(sz) * 3).toFixed(0) + 'px ' + col + ';' +
            '--dur:' + dur + 's;--del:' + del + 's;';
          atm.appendChild(el);
        }
      })();
    </script>
  </body>
</html>
