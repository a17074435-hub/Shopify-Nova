      }
      .variant-option__button-label:hover {
        border-color:rgba(168,85,247,0.65) !important;
        background:rgba(109,40,217,0.22) !important;
        color:#fff !important;
      }
      /* Botón seleccionado — morado sólido brillante */
      .variant-option__button-label:has(:checked) {
        background:linear-gradient(145deg,rgba(148,60,255,0.90) 0%,rgba(80,20,160,0.95) 100%) !important;
        border-color:rgba(168,85,247,0.90) !important;
        color:#fff !important;
        box-shadow:0 0 0 1px rgba(168,85,247,0.6),0 0 16px rgba(168,85,247,0.45) !important;
      }
      .variant-option__button-label--has-swatch:has(:checked) { outline:2px solid var(--nova-purple) !important; outline-offset:2px !important; }
      .thumbnail[aria-current="true"],.thumbnail[aria-selected="true"] { outline:2px solid var(--nova-purple) !important; outline-offset:2px !important; }

      /* Selector de cantidad — redondeado */
      .quantity-selector,
      .component-quantity,
      quantity-selector {
        border-radius:16px !important;
        border:1px solid rgba(168,85,247,0.38) !important;
        background:rgba(20,6,55,0.70) !important;
        overflow:hidden !important;
      }
      .quantity-selector__button,
      .quantity-selector__input,
      .component-quantity__input {
        background:transparent !important;
        color:#fff !important;
        border:none !important;
      }

      /* 13 — Inputs */
      input:focus-visible,textarea:focus-visible,select:focus-visible {
        outline:none !important; border-color:var(--nova-purple) !important;
        box-shadow:0 0 0 3px rgba(168,85,247,0.2) !important;
      }

      /* 14 — Cart drawer — frosted glass window */
      .cart-drawer__overlay,.drawer__overlay {
        backdrop-filter:blur(10px) brightness(0.35) !important;
        -webkit-backdrop-filter:blur(10px) brightness(0.35) !important;
        background:rgba(0,0,0,0.55) !important;
      }
      /* .cart-drawer__dialog is the actual color-scheme element — override to glass */
      /* NOTE: do NOT add .cart-drawer here — that class is on cart-drawer-component in the header */
      .cart-drawer__dialog {
        background:rgba(75,18,155,0.42) !important;
        backdrop-filter:blur(48px) saturate(1.6) !important;
        -webkit-backdrop-filter:blur(48px) saturate(1.6) !important;
        border-left:1px solid rgba(168,85,247,0.40) !important;
        border-radius:20px 0 0 20px !important;
        box-shadow:-24px 0 60px rgba(0,0,0,0.35),inset 1px 0 0 rgba(168,85,247,0.35),inset 0 1px 0 rgba(255,255,255,0.06),inset 0 0 80px rgba(109,40,217,0.12) !important;
      }
      /* cart-drawer-component wrapper in the header must be invisible */
      cart-drawer-component.cart-drawer {
        background:transparent !important;
        border:none !important;
        box-shadow:none !important;
        backdrop-filter:none !important;
      }
      /* Force all inner wrappers transparent so the glass dialog shows through */
      .cart-drawer__inner,
      .cart-drawer__content,
      .cart-drawer__items,
      scroll-hint { background:transparent !important; }
      /* Hide scrollbar inside cart while keeping scroll functional */
      .cart-drawer__dialog scroll-hint,
      .cart-drawer__content,
      .cart-drawer__items {
        scrollbar-width:none !important;
        -ms-overflow-style:none !important;
      }
      .cart-drawer__dialog scroll-hint::-webkit-scrollbar,
      .cart-drawer__content::-webkit-scrollbar,
      .cart-drawer__items::-webkit-scrollbar { display:none !important; }
      /* Cart header */
      .cart-drawer__header {
        background:rgba(168,85,247,0.07) !important;
        border-bottom:1px solid rgba(168,85,247,0.18) !important;
      }
      .cart-drawer__heading {
        color:var(--nova-purple) !important;
        text-shadow:0 0 18px rgba(168,85,247,0.5) !important;
        font-weight:700 !important;
        display:flex !important;
        align-items:center !important;
        gap:0.4em !important;
      }
      .nova-cart-heading-icon {
        display:inline-flex !important;
        align-items:center !important;
        width:1.15em !important;
        height:1.15em !important;
        flex-shrink:0 !important;
        color:var(--nova-purple) !important;
        filter:drop-shadow(0 0 8px rgba(168,85,247,0.75)) !important;
      }
      .nova-cart-heading-icon svg {
        width:100% !important;
        height:100% !important;
      }
      /* Cart item rows */
      .cart-drawer__items .cart-items__table-row {
        border-bottom:1px solid rgba(168,85,247,0.1) !important;
      }
      /* Cart product titles */
      .cart-drawer__items .cart-items__name,
      .cart-drawer__items a[href*="/products"] {
        color:var(--nova-purple) !important;
      }
      /* Cart summary footer */
      .cart-drawer__summary {
        background:rgba(168,85,247,0.06) !important;
        border-top:1px solid rgba(168,85,247,0.22) !important;
      }
      /* Checkout button — purple pill + neon glow */
      .cart-drawer__summary .button,
      .cart-drawer__summary [href*="checkout"],
      .cart__checkout-button {
        background:var(--nova-purple) !important;
        border-color:var(--nova-purple) !important;
        color:#fff !important;
        border-radius:100px !important;
        font-weight:700 !important;
        letter-spacing:0.04em !important;
        box-shadow:0 0 24px rgba(124,58,237,0.55),0 0 48px rgba(124,58,237,0.2) !important;
        transition:transform .3s var(--nova-ease),box-shadow .3s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .cart-drawer__summary .button:hover,
        .cart-drawer__summary [href*="checkout"]:hover,
        .cart__checkout-button:hover {
          transform:translateY(-3px) !important;
          box-shadow:0 0 40px rgba(124,58,237,0.75),0 0 80px rgba(124,58,237,0.35) !important;
        }
      }
      /* Quantity selector glass */
      .cart-drawer .quantity-selector,
      .cart-drawer .component-quantity {
        background:rgba(109,40,217,0.12) !important;
        border:1px solid rgba(168,85,247,0.28) !important;
        border-radius:100px !important;
      }

      /* Close buttons — spin + purple on hover (all dialogs/drawers) */
      .close-button {
        border-radius:50% !important;
        transition:transform .35s var(--nova-ease),color .3s,background .3s !important;
        padding:6px !important;
      }
      .close-button:hover {
        transform:rotate(90deg) scale(1.22) !important;
        color:var(--nova-purple) !important;
        background:rgba(168,85,247,0.12) !important;
      }
      .close-button:active {
        transform:rotate(180deg) scale(0.9) !important;
      }

      /* 15 — Popovers */
      .popover-container {
        background:rgba(8,0,28,0.92) !important;
        backdrop-filter:blur(24px) saturate(1.4) !important;
        -webkit-backdrop-filter:blur(24px) saturate(1.4) !important;
        border:1px solid rgba(168,85,247,0.24) !important;
        box-shadow:0 20px 60px rgba(0,0,0,0.65) !important;
      }
      predictive-search-component { border:1px solid rgba(168,85,247,0.2) !important; }

      /* 16 — Marquee — neon white */
      .marquee {
        border-top:1px solid rgba(168,85,247,0.25) !important;
        border-bottom:1px solid rgba(168,85,247,0.25) !important;
        background:rgba(109,40,217,0.06) !important;
      }
      .marquee .text-block > *,
      .marquee p,
      .marquee span {
        color:#fff !important;
        text-shadow:0 0 18px rgba(255,255,255,0.7),0 0 40px rgba(255,255,255,0.3) !important;
        opacity:1 !important;
