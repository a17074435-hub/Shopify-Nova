<!doctype html>
<html lang="{{ request.locale.iso_code }}" {% if request.design_mode %}class="shopify-design-mode"{% endif %}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#000000">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}

  <!-- Preconnect para fonts -->
  {% comment %}theme-check-disable RemoteAsset{% endcomment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  {% comment %}theme-check-enable RemoteAsset{% endcomment %}

  <!-- Critical CSS -->
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'sections.css' | asset_url | stylesheet_tag }}

  <!-- Fonts del theme picker -->
  {%- unless settings.type_body_font.system? -%}
    <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" crossorigin>
  {%- endunless -%}
  {%- unless settings.type_heading_font.system? -%}
    <link rel="preload" as="font" href="{{ settings.type_heading_font | font_url }}" crossorigin>
  {%- endunless -%}

  <!-- View transitions -->
  {%- if settings.enable_view_transitions -%}
    <meta name="view-transition" content="same-origin">
  {%- endif -%}

  {{ content_for_header }}

  <!-- Cart state inicial -->
  <script>
    window.__NOVA__ = {
      cartCount: {{ cart.item_count }},
      cartItems: {{ cart.items | json }},
      cartTotal: {{ cart.total_price }},
      currency: {{ shop.currency | json }},
      moneyFormat: {{ shop.money_format | json }},
      shopDomain: {{ shop.permanent_domain | json }},
      locale: {{ request.locale.iso_code | json }},
      enableAnimations: {{ settings.enable_animations | json }},
      enableStarfield: {{ settings.enable_starfield | json }},
      starfieldDensity: {{ settings.starfield_density }},
      enableToasts: {{ settings.enable_recent_buyers_toast | json }},
      freeShippingThreshold: {{ settings.free_shipping_threshold | times: 100 }},
      urgencyMessages: {{ settings.urgency_messages | split: '\n' | json }},
      countdownHours: {{ settings.countdown_hours }},
      enableCountdown: {{ settings.enable_countdown | json }}
    };
  </script>
</head>

<body class="template-{{ template.name | handle }}">
  <!-- SVG icon sprite -->
  {%- assign icons_svg = 'icons.svg' | asset_url -%}
  <div style="display:none" aria-hidden="true">{% render 'icon-sprite' %}</div>

  <!-- Toast stack (compradores recientes) -->
  <div class="toast-stack" id="nova-toast-stack" aria-live="polite" aria-atomic="true"></div>

  {%- section 'header' -%}

  <main id="MainContent" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- render 'nova-footer' -%}

  <!-- Cart drawer (global) -->
  <nova-cart-drawer id="nova-cart-drawer"></nova-cart-drawer>

  <!-- Search modal -->
  <nova-search-modal id="nova-search-modal"></nova-search-modal>

  <!-- Account modal -->
  <nova-account-modal id="nova-account-modal"></nova-account-modal>

  <!-- Scripts diferidos -->
  <script src="{{ 'cart.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-dock.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-cart-drawer.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-search-modal.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-account-modal.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-reveal.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-toast.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-countdown.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-marquee.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-product-gallery.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-color-picker.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-bundle.js' | asset_url }}" defer></script>
  <script src="{{ 'nova-price-slider.js' | asset_url }}" defer></script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
