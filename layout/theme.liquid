<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
      /* ── NovaLight v2 ── */
      :root {
        --nova-purple: #A855F7;
        --nova-glow: rgba(124,58,237,0.18);
        --nova-ease: cubic-bezier(0.16,1,0.3,1);
        /* CSS variable overrides — win by source order after theme-styles-variables */
        --font-heading--family:    'Space Grotesk',-apple-system,sans-serif;
        --font-subheading--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h1--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h2--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h3--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h4--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h5--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-h6--family: 'Space Grotesk',-apple-system,sans-serif;
        --font-size--h1: clamp(3rem,8vw,6.5rem);
        --font-size--h2: clamp(2rem,5vw,4rem);
        --font-size--h3: clamp(1.5rem,3vw,2.5rem);
        --font-h1--size: clamp(3rem,8vw,6.5rem);
        --font-h2--size: clamp(2rem,5vw,4rem);
        --font-h3--size: clamp(1.5rem,3vw,2.5rem);
        --letter-spacing--heading-tight:  -0.04em;
        --letter-spacing--heading-normal: -0.02em;
        --letter-spacing--display-tight:  -0.045em;
        --line-height--heading-tight:  1.05;
        --line-height--heading-normal: 1.1;
      }
      /* Direct font rules — bypass variable chain entirely */
      .text-block.h1 > *,
      .text-block.h1 :is(h1,h2,h3,h4,h5,h6),
      .text-block.h2 > *,
      .text-block.h2 :is(h1,h2,h3,h4,h5,h6),
      .text-block.h3 > *,
      .text-block.h3 :is(h1,h2,h3,h4,h5,h6),
      h1, h2, h3 {
        font-family: 'Space Grotesk',-apple-system,sans-serif !important;
      }
      .text-block.h1 > * { font-size: clamp(3rem,8vw,6.5rem) !important; letter-spacing:-0.04em !important; line-height:1.05 !important; }
      .text-block.h2 > * { font-size: clamp(2rem,5vw,4rem)   !important; letter-spacing:-0.03em !important; line-height:1.1  !important; }
      .text-block.h3 > * { font-size: clamp(1.5rem,3vw,2.5rem) !important; }
      body { -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }
      /* Hero — glow overlay, no grid so it's not subtle */
      .hero { position:relative !important; overflow:hidden; }
      .hero::after {
        content:'' !important; position:absolute !important; inset:0 !important;
        pointer-events:none !important; z-index:3 !important;
        background:radial-gradient(ellipse 90% 55% at 50% 110%,rgba(124,58,237,0.45) 0%,transparent 60%) !important;
      }
      .hero .text-block.h1 > *, .hero .text-block.h1 :is(h1,h2,h3,h4,h5,h6) {
        font-weight:700 !important; text-shadow:0 2px 40px rgba(0,0,0,0.6) !important; position:relative; z-index:4;
      }
      .hero .text-block.paragraph > *, .hero .text-block.rte p {
        opacity:0.75 !important; line-height:1.65 !important; position:relative; z-index:4;
      }
      .hero hr { border-color:rgba(168,85,247,0.6) !important; width:36px !important; }
      /* Sticky header glass */
      header-component[data-sticky-state="active"] .header,
      header-component[sticky="always"] .header {
        backdrop-filter:blur(20px) saturate(1.8) !important;
        -webkit-backdrop-filter:blur(20px) saturate(1.8) !important;
        background-color:rgba(0,0,0,0.82) !important;
        border-bottom:1px solid rgba(255,255,255,0.07) !important;
      }
      .header__nav-link:hover,.header__nav-link:focus-visible { color:var(--nova-purple) !important; }
      /* Announcement bar */
      .announcement-bar__text,.announcement-bar {
        font-size:0.7rem !important; letter-spacing:0.08em !important; text-transform:uppercase !important;
      }
      /* Product cards */
      .product-card {
        border-radius:4px !important; overflow:hidden !important;
        transition:transform .4s var(--nova-ease),box-shadow .4s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) and (prefers-reduced-motion:no-preference) {
        .product-card:hover {
          transform:translateY(-5px) !important;
          box-shadow:0 24px 60px rgba(0,0,0,0.6),0 0 0 1px rgba(168,85,247,0.15) !important;
        }
      }
      /* Primary button — on hover turns purple with glow (design-preview style) */
      .button:not(.button-secondary,.button-unstyled) {
        transition:background-color .4s var(--nova-ease),color .4s var(--nova-ease),box-shadow .4s var(--nova-ease),transform .22s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .button:not(.button-secondary,.button-unstyled):hover {
          background-color: var(--nova-purple) !important;
          border-color: var(--nova-purple) !important;
          color: #fff !important;
          transform:translateY(-2px) !important;
          box-shadow:0 0 32px rgba(124,58,237,0.45),0 0 64px rgba(124,58,237,0.2) !important;
        }
        .button:not(.button-secondary,.button-unstyled):active { transform:translateY(0) !important; }
      }
      /* Secondary / ghost button — purple border, transparent bg */
      .button-secondary {
        border: 1px solid rgba(168,85,247,0.5) !important;
        color: #fff !important;
        background: transparent !important;
        transition:border-color .4s var(--nova-ease),box-shadow .4s var(--nova-ease),background .4s var(--nova-ease),transform .22s var(--nova-ease) !important;
      }
      @media (any-pointer:fine) {
        .button-secondary:hover {
          border-color: var(--nova-purple) !important;
          background: rgba(168,85,247,0.08) !important;
          box-shadow:0 0 24px rgba(124,58,237,0.3) !important;
          transform:translateY(-2px) !important;
        }
        .button-secondary:active { transform:translateY(0) !important; }
      }
      /* Purple accents */
      .badge--sale { background-color:var(--nova-purple) !important; border-color:var(--nova-purple) !important; color:#fff !important; }
      .variant-option__button-label:has(:checked) { box-shadow:0 0 0 2px var(--nova-purple) !important; }
      .variant-option__button-label--has-swatch:has(:checked) { outline:2px solid var(--nova-purple) !important; outline-offset:2px !important; }
      input:focus-visible,textarea:focus-visible,select:focus-visible {
        outline:none !important; border-color:var(--nova-purple) !important;
        box-shadow:0 0 0 3px rgba(168,85,247,0.18) !important;
      }
      /* Cart glass */
      .cart-drawer__overlay,.drawer__overlay { backdrop-filter:blur(6px) !important; -webkit-backdrop-filter:blur(6px) !important; }
      .cart-drawer { border-left:1px solid rgba(255,255,255,0.07) !important; }
      .popover-container { backdrop-filter:blur(16px) !important; -webkit-backdrop-filter:blur(16px) !important; border:1px solid rgba(255,255,255,0.08) !important; }
      /* Scrollbar */
      ::-webkit-scrollbar { width:5px; }
      ::-webkit-scrollbar-track { background:transparent; }
      ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.08); border-radius:99px; }
      ::-webkit-scrollbar-thumb:hover { background:var(--nova-purple); }
      /* Logo */
      .nova-logo__img { height:30px !important; width:auto !important; max-width:200px !important; display:block !important; }
      @media (max-width:749px) { .nova-logo__img { height:24px !important; } }
    </style>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
