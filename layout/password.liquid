<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {%- render 'meta-tags' -%}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <style>
    body { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--bg-cosmic); }
    .password-card { max-width: 440px; width: 100%; padding: 48px 40px; background: var(--bg-card); border: 1px solid var(--border-cosmic); border-radius: 20px; text-align: center; }
    .password-card h1 { font-size: 32px; margin-bottom: 12px; }
    .password-card p { color: var(--fg); margin-bottom: 28px; }
    .password-form { display: flex; flex-direction: column; gap: 12px; }
    .password-form input { padding: 14px 16px; background: var(--bg-elevated); border: 1px solid var(--border-strong); border-radius: var(--r-md); color: var(--fg-heading); font-size: 15px; outline: none; }
    .password-form input:focus { border-color: var(--primary); }
    .password-footer { margin-top: 32px; font-size: 12px; color: var(--fg-muted); }
    .password-footer a { color: var(--primary); }
  </style>
</head>
<body>
  <div class="password-card">
    <div style="margin-bottom: 24px;">
      <svg width="36" height="36" viewBox="0 0 32 32" style="margin: 0 auto;">
        <circle cx="16" cy="16" r="6" fill="#A855F7"/>
        <ellipse cx="16" cy="16" rx="14" ry="5" fill="none" stroke="#A855F7" stroke-width="0.8" opacity="0.5" transform="rotate(-25 16 16)"/>
      </svg>
    </div>
    <h1>{{ shop.name }}</h1>
    <p>{{ 'general.password_page.opening_soon' | t }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color: var(--danger); font-size: 13px; margin-bottom: 12px;">{{ 'general.password_page.password_error' | t }}</p>
      {%- endif -%}
      <div class="password-form">
        <input type="password" name="password" placeholder="{{ 'general.password_page.password_placeholder' | t }}" autocomplete="current-password">
        <button type="submit" class="btn btn-glow">{{ 'general.password_page.enter_store' | t }}</button>
      </div>
    {%- endform -%}

    <div class="password-footer">
      {{ 'general.password_page.powered_by_shopify_html' | t }}
    </div>
  </div>
  <div style="display:none;">{{ content_for_layout }}</div>
</body>
</html>
