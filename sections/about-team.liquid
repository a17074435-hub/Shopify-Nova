<section class="about-team-section">
  <div class="container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="about-team__eyebrow reveal">{{ section.settings.eyebrow | upcase }}</p>
    {%- endif -%}
    <h2 class="about-team__title reveal reveal-delay-1">{{ section.settings.heading }}</h2>

    <div class="about-team__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'member' -%}
          <div class="team-card reveal reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
            {%- if block.settings.photo != blank -%}
              <div class="team-card__avatar-wrap">
                {{ block.settings.photo | image_url: width: 160 | image_tag:
                  loading: 'lazy',
                  class: 'team-card__photo',
                  alt: block.settings.name | escape
                }}
              </div>
            {%- else -%}
              <div class="team-card__avatar">
                {{ block.settings.initial | default: block.settings.name | slice: 0 }}
              </div>
            {%- endif -%}

            <div class="team-card__name">{{ block.settings.name }}</div>
            <div class="team-card__role">{{ block.settings.role }}</div>

            {%- if block.settings.quote != blank -%}
              <p class="team-card__quote">"{{ block.settings.quote }}"</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.about-team-section {
  padding: var(--section-py, 120px) 0;
  background: var(--bg, #000);
}
.about-team__eyebrow {
  font-size: 11px;
  letter-spacing: 0.16em;
  color: var(--fg-lavender, #C4B5FD);
  text-align: center;
  margin-bottom: 20px;
  font-weight: 500;
  border: 1px solid var(--border-cosmic, #2A1A4E);
  display: inline-block;
  padding: 6px 16px;
  border-radius: var(--r-pill, 40px);
  background: var(--primary-soft, rgba(168,85,247,0.1));
  width: 100%;
  max-width: max-content;
  margin-left: auto; margin-right: auto;
  display: flex; justify-content: center;
}
.about-team__title {
  font-size: clamp(28px, 4vw, 52px);
  text-align: center;
  margin-bottom: 56px;
  font-family: var(--font-heading);
  font-weight: 400;
  letter-spacing: -0.03em;
}
.about-team__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px;
  max-width: 760px;
  margin: 0 auto;
}

/* Team card */
.team-card {
  text-align: center;
  padding: 32px 24px;
  background: var(--bg-card, #111);
  border: 1px solid var(--border, #1E1E1E);
  border-radius: 20px;
  transition: border-color 0.3s, transform 0.3s;
}
.team-card:hover { border-color: var(--primary-deep, #7C3AED); transform: translateY(-4px); }
.team-card__avatar-wrap {
  width: 80px; height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 20px;
  border: 2px solid var(--border-cosmic, #2A1A4E);
}
.team-card__photo { width:100%; height:100%; object-fit:cover; }
.team-card__avatar {
  width: 80px; height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary, #A855F7), var(--primary-deep, #7C3AED));
  display: grid;
  place-items: center;
  font-size: 28px;
  font-weight: 700;
  color: #fff;
  margin: 0 auto 20px;
}
.team-card__name {
  font-size: 16px;
  font-weight: 600;
  color: var(--fg-heading, #fff);
  margin-bottom: 4px;
  font-family: var(--font-heading);
}
.team-card__role {
  font-size: 11px;
  color: var(--primary, #A855F7);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 14px;
}
.team-card__quote {
  font-size: 13px;
  color: var(--fg-muted, #6B6B6B);
  line-height: 1.55;
  font-style: italic;
}
</style>

{% schema %}
{
  "name": "About Equipo",
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow", "default": "El equipo" },
    { "type": "text", "id": "heading",  "label": "Título",  "default": "Tres humanos y muchas estrellas." }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Miembro del equipo",
      "settings": [
        { "type": "image_picker", "id": "photo",   "label": "Foto" },
        { "type": "text",         "id": "initial", "label": "Inicial (si no hay foto)" },
        { "type": "text",         "id": "name",    "label": "Nombre",    "default": "Mateo Ruiz" },
        { "type": "text",         "id": "role",    "label": "Rol",       "default": "CEO · Co-fundador" },
        { "type": "text",         "id": "quote",   "label": "Cita",      "default": "Si no lo soñamos en grande, mejor no soñamos." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "member", "settings": { "initial": "M", "name": "Mateo Ruiz",  "role": "CEO · Co-fundador",    "quote": "Si no lo soñamos en grande, mejor no soñamos." } },
      { "type": "member", "settings": { "initial": "L", "name": "Lucía Vega",  "role": "Diseño · Co-fundadora","quote": "La forma cuenta historias que las palabras no pueden." } },
      { "type": "member", "settings": { "initial": "H", "name": "Hugo Martín", "role": "Tech · Co-fundador",   "quote": "El detalle invisible es el que hace que todo funcione." } }
    ]
  },
}
{% endschema %}
