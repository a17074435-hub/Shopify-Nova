{%- if section.settings.show_announcement -%}
<div class="announcement-bar" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};padding:10px 16px;text-align:center;font-size:13px;font-weight:500;position:relative;">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" style="color:inherit;text-decoration:none;">{{ section.settings.text }}</a>
  {%- else -%}
    {{ section.settings.text }}
  {%- endif -%}
  <button
    class="announcement-close"
    onclick="this.closest('.announcement-bar').style.display='none'"
    style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:inherit;cursor:pointer;opacity:.7;line-height:1;"
    aria-label="Cerrar">
    {% render 'icon', icon: 'close' %}
  </button>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Barra de anuncio",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Mostrar barra", "default": true },
    { "type": "text", "id": "text", "label": "Texto", "default": "🚀 Envío gratis en pedidos +50€ · Garantía 2 años" },
    { "type": "url", "id": "link", "label": "Enlace (opcional)" },
    { "type": "color", "id": "bg_color", "label": "Color de fondo", "default": "#A855F7" },
    { "type": "color", "id": "text_color", "label": "Color de texto", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "Barra de anuncio" }]
}
{% endschema %}
