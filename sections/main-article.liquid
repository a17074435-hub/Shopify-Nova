<section class="generic-page">
  <div class="container">
    {%- render 'breadcrumbs' -%}
    <div class="generic-page__content" style="max-width:720px;">
      <div style="margin-bottom:32px;">
        {%- if article.image -%}
          {{ article.image | image_url: width: 1400 | image_tag:
            loading: 'eager',
            sizes: '(min-width: 720px) 720px, 100vw',
            widths: '720, 1000, 1400',
            style: 'width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:16px;margin-bottom:32px;',
            alt: article.image.alt | escape
          }}
        {%- endif -%}
        <p style="font-size:12px;color:var(--fg-muted);margin-bottom:12px;">{{ article.published_at | date: '%d %B %Y' }} · por {{ article.author }}</p>
        <h1 style="font-size:clamp(28px,4vw,52px);margin-bottom:16px;">{{ article.title }}</h1>
      </div>
      <div class="article-content" style="font-size:17px;line-height:1.75;color:var(--fg);">
        {{ article.content }}
      </div>

      <!-- Tags -->
      {%- if article.tags.size > 0 -%}
        <div style="margin-top:40px;display:flex;gap:8px;flex-wrap:wrap;">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="pill pill-primary">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <!-- Nav -->
      <div style="display:flex;justify-content:space-between;margin-top:48px;padding-top:24px;border-top:1px solid var(--border);">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article }}" style="color:var(--primary);font-size:14px;">← Anterior</a>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article }}" style="color:var(--primary);font-size:14px;">Siguiente →</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Artículo",
  "settings": []
}
{% endschema %}
