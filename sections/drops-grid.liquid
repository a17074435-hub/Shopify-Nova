<section class="drops-grid section-py">
  <div class="container-wide">
    <div class="drops-header">
      <div class="drops-header__left">
        <span class="pill pill-live">Drop limitado</span>
        <h2 style="margin-top:12px;">{{ section.settings.heading }}</h2>
      </div>
      <div class="drops-header__right">
        {%- if section.settings.show_countdown and settings.enable_countdown -%}
          <div class="drops-header__countdown">
            <span class="pill pill-primary">⏱ Acaba en</span>
            <nova-countdown data-hours="{{ settings.countdown_hours }}"></nova-countdown>
          </div>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p style="color:var(--fg);max-width:360px;margin-bottom:12px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.view_all_label != blank -%}
          <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" style="color:var(--primary);font-size:14px;font-weight:500;">
            {{ section.settings.view_all_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- liquid
      assign coll = collections[section.settings.collection]
      if coll == blank or coll.products_count == 0
        assign coll = collections.all
      endif
    -%}
    <div class="drops-grid__grid">
      {%- for product in coll.products limit: section.settings.products_per_row -%}
        {%- render 'product-card', product: product, skip_reveal: true -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.products_per_row -%}
          {%- render 'product-card', product: product, skip_reveal: true -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Drops Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "El catálogo de esta semana" },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Solo 4 productos. Solo 7 días. Cuando se acaban, no vuelven." },
    { "type": "collection", "id": "collection", "label": "Colección de drops" },
    { "type": "range", "id": "products_per_row", "label": "Productos a mostrar", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_countdown", "label": "Mostrar countdown", "default": true },
    { "type": "text", "id": "view_all_label", "label": "Texto ver todo", "default": "Ver todo el catálogo →" },
    { "type": "url", "id": "view_all_link", "label": "Enlace ver todo" }
  ],
  "presets": [{ "name": "Drops Grid" }]
}
{% endschema %}
