<section class="faq-section">
  <div class="container-narrow">
    {%- if section.settings.eyebrow != blank -%}
      <div class="section-eyebrow reveal" style="justify-content:center;">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1 style="text-align:center;margin:16px 0 0;" class="reveal">{{ section.settings.heading }}</h1>

    <nova-accordion class="faq-list" data-only-one="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          <div class="accordion-item reveal reveal-delay-{{ forloop.index | modulo: 5 | plus: 1 }}" {{ block.shopify_attributes }}>
            <button type="button" class="accordion-trigger" aria-expanded="false">
              {{ block.settings.question }}
              {%- render 'icon', icon: 'chevron-down', size: 18 -%}
            </button>
            <div class="accordion-body">
              <div class="accordion-body-inner">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nova-accordion>
  </div>
</section>

<script src="{{ 'nova-accordion.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ Cósmico",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Todo lo que necesitas saber" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Preguntas frecuentes" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Pregunta",
      "settings": [
        { "type": "text", "id": "question", "label": "Pregunta" },
        { "type": "richtext", "id": "answer", "label": "Respuesta" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
