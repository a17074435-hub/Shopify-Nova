<section class="featured-section">
  <div class="container-wide">
    <div class="featured-header reveal">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_link | default: '/collections/all' }}">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>

    {%- assign coll = collections[section.settings.collection] -%}
    <div class="carousel__track">
      {%- for product in coll.products limit: section.settings.products_to_show -%}
        <div class="reveal reveal-delay-{{ forloop.index }}">
          {%- render 'product-card', product: product -%}
        </div>
      {%- else -%}
        <p style="color:var(--fg-muted);text-align:center;padding:40px;grid-column:1/-1;">
          Conecta una colección en el editor de tema para mostrar productos.
        </p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Colección destacada",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Más vendidos" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "range", "id": "products_to_show", "label": "Productos a mostrar", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "view_all_label", "label": "Texto ver todos", "default": "Ver todos →" },
    { "type": "url", "id": "view_all_link", "label": "Enlace ver todos" }
  ],
  "presets": [{ "name": "Colección destacada" }]
}
{% endschema %}
