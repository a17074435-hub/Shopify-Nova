<section class="section-py" style="text-align:center;min-height:60vh;display:flex;align-items:center;">
  <div class="container">
    <div class="page-404__num">404</div>
    <h1 style="font-size:clamp(24px,3vw,40px);margin-bottom:16px;">{{ section.settings.heading }}</h1>
    <p style="color:var(--fg-muted);max-width:480px;margin:0 auto 32px;">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_url | default: '/' }}" class="btn btn-primary btn-glow">
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Página 404",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Página no encontrada" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "La página que buscas no existe o fue movida." },
    { "type": "text", "id": "button_label", "label": "Texto del botón", "default": "Volver al inicio" },
    { "type": "url", "id": "button_url", "label": "URL del botón" }
  ]
}
{% endschema %}
